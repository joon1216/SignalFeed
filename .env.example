# SignalFeed 환경 설정 템플릿 (Session 45 현행화)
# ─────────────────────────────────────────────
# 이 파일을 복사해서 .env 로 저장 후 실제 값을 입력하세요
#
#   cp .env.example .env
#
# ⚠️  .env 파일은 절대 Git에 커밋하지 마세요 (API 키 포함)
# ─────────────────────────────────────────────

# ── Finnhub API (글로벌 경제 뉴스 수집) — 필수 ─────────────────────
# 발급: https://finnhub.io/dashboard
# 무료 플랜: 60 req/min
FINNHUB_API_KEY=your_finnhub_api_key_here

# ── Gemini 2.5 Flash API (콘텐츠 생성) — 선택 ──────────────────────
# 발급: https://aistudio.google.com/app/apikey
# 무료 티어 일일 쿼터 매우 작음 (실측 ~20 req/day) — gen_cache가 보호
# 없으면 큐레이션 fallback 콘텐츠로 동작
GEMINI_API_KEY=your_gemini_api_key_here

# ── Pixabay API (카드 커버 배경 이미지) — 선택 ─────────────────────
# 발급: https://pixabay.com/api/docs/
# 없으면 단색 배경 fallback
PIXABAY_API_KEY=your_pixabay_api_key_here

# ── Instagram 벤치마크 발굴 (backend/reference/discover.py) — 선택 ─
# instaloader --login <내계정> 으로 세션 파일 생성 후 경로 지정
# (보통 ~/.config/instaloader/session-<계정명>)
# 없으면 익명 시도 (rate limit 더 엄격)
IG_SESSION_FILE=
IG_USERNAME=

# ── 자동 업로드 (Phase 2 — 아직 미사용) ────────────────────────────
INSTAGRAM_ACCESS_TOKEN=
YOUTUBE_API_KEY=
