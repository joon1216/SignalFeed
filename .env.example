# IssueFit 환경 설정 템플릿
# ─────────────────────────────────────────────
# 이 파일을 복사해서 .env 로 저장 후 실제 값을 입력하세요
#
#   cp .env.example .env
#
# ⚠️  .env 파일은 절대 Git에 커밋하지 마세요 (API 키 포함)
# ─────────────────────────────────────────────

# ── 네이버 검색 API (크롤링 파이프라인 실행 시 필요) ──────────────
# 발급: https://developers.naver.com/apps/#/register
NAVER_CLIENT_ID=여기에_클라이언트_ID_입력
NAVER_CLIENT_SECRET=여기에_클라이언트_시크릿_입력

# ── Ollama LLM 서버 주소 ──────────────────────────────────────────
# 로컬 직접 실행:  http://localhost:11434
# Docker 실행 시: docker-compose.yml 에서 자동으로 http://ollama:11434 로 덮어씀
OLLAMA_BASE_URL=http://localhost:11434

# ── Ollama 모델 이름 ──────────────────────────────────────────────
# 권장: gemma2:2b (빠름, 1.6GB), gemma2:9b (정확함, 5.4GB)
OLLAMA_MODEL=gemma2:2b

# ── 크롤링 설정 ───────────────────────────────────────────────────
MAX_ARTICLES_PER_KEYWORD=100
CRAWL_DELAY_SECONDS=0.5
