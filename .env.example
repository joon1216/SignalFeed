# SignalFeed 환경 설정 템플릿
# ─────────────────────────────────────────────
# 이 파일을 복사해서 .env 로 저장 후 실제 값을 입력하세요
#
#   cp .env.example .env
#
# ⚠️  .env 파일은 절대 Git에 커밋하지 마세요 (API 키 포함)
# ─────────────────────────────────────────────

# ── Polygon.io API (미국 주식 뉴스) ────────────────────────────────
# 발급: https://polygon.io/dashboard/api-keys
# 무료 플랜: 5 req/min
POLYGON_API_KEY=your_polygon_api_key_here

# ── Finnhub API (글로벌 경제 뉴스) ─────────────────────────────────
# 발급: https://finnhub.io/dashboard
# 무료 플랜: 60 req/min
FINNHUB_API_KEY=your_finnhub_api_key_here

# ── OpenAI API (자동 레이블링, 가짜뉴스 검증) ────────────────────
# 발급: https://platform.openai.com/api-keys
# GPT-4o-mini: $0.15/1M tokens
OPENAI_API_KEY=your_openai_api_key_here

# ── EXAONE 3.5 API (콘텐츠 생성) ───────────────────────────────────
# 발급: LG AI Research (무료)
# TODO: 발급 URL 추가 필요
EXAONE_API_KEY=your_exaone_api_key_here

# ── Instagram Graph API (자동 업로드) ──────────────────────────────
# 발급: https://developers.facebook.com/apps/
# Phase 5.6에서 사용
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here

# ── YouTube Data API v3 (Shorts 업로드) ────────────────────────────
# 발급: https://console.cloud.google.com/apis/credentials
# Phase 5.7에서 사용
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Pexels API (카드 배경 이미지) ──────────────────────────────────
# 발급: https://www.pexels.com/api/
# 무료 플랜: 200 req/hour
PEXELS_API_KEY=your_pexels_api_key_here

# ── 크롤링 설정 ───────────────────────────────────────────────────
MAX_ARTICLES_PER_SOURCE=50
COLLECTION_DELAY_SECONDS=12
